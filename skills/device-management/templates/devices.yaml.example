# devices.yaml.example - 设备清单模板
#
# 使用说明：
#   1. 复制本文件到用户工作区根目录，重命名为 devices.yaml
#   2. 复制 .env.example 为 .env，填入实际凭据值
#   3. 将 devices.yaml 和 .env 加入 .gitignore（禁止入库明文凭据）
#
# 凭据安全（强制规则）：
#   - 所有 password 字段必须使用 ${ENV_VAR} 占位（正则 ^\$\{[A-Z_][A-Z0-9_]*\}$）
#   - 禁止明文凭据写入 devices.yaml
#   - 运行时由 collect_sysinfo.py 从环境变量解析实际值
#
# Schema 字段说明：
#   device_groups[]          设备组列表
#     name                   设备组名（唯一标识）
#     description            设备描述（可选）
#     firewall               防火墙设备块
#       host                 管理 IP
#       role                 固定值 firewall
#       device_type          TGFW 型号（查 reference/device-reference.md）
#       web                  Web 管理连接
#         host / port / user / password
#       telnet               Telnet 连接（SSH 回退用）
#         host / port / user / password
#       ssh                  SSH 连接（首选）
#         host / port / user / password / enabled
#     tags                   标签列表（可选）

device_groups:
  # 示例 1：防火墙设备（含 web/telnet/ssh 三种连接方式）
  - name: hg3250-51
    description: "防火墙设备 HG3250-51（乐研海光3250）"

    firewall:
      host: <IP_ADDRESS>
      role: firewall
      device_type: DAS-TGFW-A1300-HU
      web:
        host: <IP_ADDRESS>
        port: 443
        user: admin
        password: ${FW_WEB_PASSWORD}
      telnet:
        host: <IP_ADDRESS>
        port: 10004
        user: root
        password: ${FW_TELNET_PASSWORD}
      ssh:
        host: <IP_ADDRESS>
        port: 22
        user: root
        password: ${FW_SSH_PASSWORD}
        enabled: false  # 需通过串口开启

    tags:
      - firewall
      - hg3250

  # 示例 2：防火墙设备（SSH 已启用，首选 SSH 采集）
  - name: 160pro-32
    description: "防火墙设备 160pro-32（nxp1043）"

    firewall:
      host: <IP_ADDRESS>
      role: firewall
      device_type: DAS-TGFW-160-PRO
      web:
        host: <IP_ADDRESS>
        port: 443
        user: admin
        password: ${FW_WEB_PASSWORD}
      telnet:
        host: <IP_ADDRESS>
        port: 10013
        user: root
        password: ${FW_TELNET_PASSWORD}
      ssh:
        host: <IP_ADDRESS>
        port: 22
        user: root
        password: ${FW_SSH_PASSWORD}
        enabled: true

    tags:
      - firewall
      - nxp1043
