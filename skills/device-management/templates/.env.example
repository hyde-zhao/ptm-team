# .env.example - 凭据环境变量清单
#
# 使用说明：
#   1. 复制本文件到用户工作区根目录，重命名为 .env
#   2. 在等号后填入实际凭据值
#   3. 将 .env 加入 .gitignore（禁止入库明文凭据）
#
# 对应 devices.yaml 中的 ${ENV_VAR} 占位符，collect_sysinfo.py 运行时从环境变量解析。

FW_WEB_PASSWORD=          # 防火墙 Web 管理密码（对应 ${FW_WEB_PASSWORD}）
FW_SSH_PASSWORD=          # 防火墙 SSH 密码（对应 ${FW_SSH_PASSWORD}）
FW_TELNET_PASSWORD=       # 防火墙 Telnet 密码（对应 ${FW_TELNET_PASSWORD}）
